scene BottleMeshTest

component Bottle
    mesh Shell
        cylinder Body
            at 0 1 0
            radius 1
            height 2
            color white

        cylinder Neck
            at 0 2.3 0
            radius 0.4
            height 0.6
            color white

    cylinder Water
        at 0 1 0
        radius 0.8
        height 1.5
        color blue

    cylinder Cap
        at 0 2.7 0
        radius 0.45
        height 0.2
        color blue

    cylinder Label
        at 0 1 0
        radius 1.02
        height 0.7
        color red

instance Bottle Bottle
